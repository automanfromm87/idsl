# Carriers are reusable across orders; declare each once and reference
# by name in JSON inputs (`{"$ref": "UPS"}`) or DSL test blocks
# (`Carriers = [UPS, USPS]`).

schema Carrier:
  - Name:    e.g. "ACME Logistics"
  - Express: e.g. true

instance Carrier UPS:
  Name    = "UPS"
  Express = true

instance Carrier USPS:
  Name    = "USPS"
  Express = false

instance Carrier DHL:
  Name    = "DHL"
  Express = true
